# Copy to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...      # Slack app → OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...      # Slack app → Basic Information → App-Level Tokens (connections:write)
MACHINE_NAME=desktop            # this machine's name — commands target it as /desktop

# ── Strongly recommended ────────────────────────────────────────────────────
# Slack user IDs allowed to command the bot (comma-separated). Empty = EVERYONE
# in the workspace can execute code on your machine.
# ALLOWED_USERS=U0XXXXXXXXX,U0YYYYYYYYY

# ── Optional ────────────────────────────────────────────────────────────────
# WORK_DIR=/home/you/Projects          # where claude runs (absolute path); default ~/Projects
# IS_GATEWAY=true                      # set false on worker machines that shouldn't route

# One line per remote worker the gateway can reach over SSH (key-based auth):
# SSH_server=you@server.example.com
# SSH_cluster=you@10.0.0.7:43284

# Override the auto-derived machine list (this machine + all SSH_ entries):
# KNOWN_MACHINES=desktop,server,cluster

# Per-channel default target machine:
# CHANNEL_DEFAULTS=C0AAAAAAAAA:server,C0BBBBBBBBB:cluster

# Auto-commit & push contexts/<channel>.md to origin after each command (multi-
# machine memory sync). Set false on single-machine setups or when origin is a
# public repo — contexts then stay as plain local files.
# CONTEXT_GIT_SYNC=true

# Friendly channel names for terminal mode (/channel, /slack, chat_to_slack.py):
# CHANNEL_NAMES=my-project:C0AAAAAAAAA,lab-general:C0BBBBBBBBB

# Attachment mode: full (default) = agent may read any attachment; text = only
# text-like files (code, logs, csv) are passed through, images/video/docs/zips are
# skipped to save tokens; none = ignore attachments. Per-message: --attachments text
# ATTACHMENT_MODE=full

# CLAUDE_MODEL=                        # default Claude model (empty = claude CLI default)
# CODEX_MODEL=gpt-4.1                  # default model for the codex runner

# IDEAS_VAULT=/home/you/ideas-vault    # enables /idea capture into an Obsidian-style vault

# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # notify.py fallback channel

# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080
# DASHBOARD_AUTO_END_HOURS=24    # auto-end threads idle this long (0 = never)

# ALIVE_REACTION=eye                   # 👁 the bot adds to a thread's first message while it's on the dashboard
# ARCHIVE_REACTION=file_folder         # user-owned emoji: add to archive a thread, remove to revive
